# A sample Dockerfile for a Triton inference backend with DeepStream-
# accelerated ImageInputDataFlow and CVCUDA for pre-processing.

# Pull the base image from Deepstream Triton multiarch image.
FROM "nvcr.io/nvidia/deepstream:9.0-triton-multiarch" AS builder_base

# Install the Python dependencies required by THIS changenet sample
# backend. These versions are pinned for reproducibility and may be
# adjusted for other pipelines or environments.
RUN --mount=type=cache,target=/root/.cache/pip \
    pip install \
    requests==2.32.3 \
    python-multipart==0.0.9 \
    aiofiles==23.2.1 \
    aiohttp==3.11.0 \
    annotated-types==0.7.0 \
    python-magic==0.4.27 \
    torch==2.7.0 --extra-index-url https://download.pytorch.org/whl/cu128 \
    torchvision==0.22.0 \
    Pillow==11.1.0 \
    open_clip_torch==2.30.0 \
    numpy==1.26.4 \
    omegaconf==2.3.0 \
    transformers==4.48.0 \
    fastapi==0.115.12 \
    uvicorn==0.29.0 \
    tritonclient[all]==2.63.0

# Install CVCUDA for pre-processing.
# NOTE: These .deb files are built for x86_64 and specific CUDA/Python
# versions. For different architectures or CUDA/Python versions you may
# need to update these URLs to a compatible CVCUDA release.
RUN wget https://github.com/CVCUDA/CV-CUDA/releases/download/v0.16.0/cvcuda-lib-0.16.0-cuda13-x86_64-linux.deb \
    https://github.com/CVCUDA/CV-CUDA/releases/download/v0.16.0/cvcuda-dev-0.16.0-cuda13-x86_64-linux.deb \
    https://github.com/CVCUDA/CV-CUDA/releases/download/v0.16.0/cvcuda-python3.12-0.16.0-cuda13-x86_64-linux.deb \
    && dpkg -i *.deb

ENV TRANSFORMERS_CACHE=/tmp

WORKDIR /workspace

# Copy the inference flow package generated by Inference Builder.
# This tarball (here: changenet.tgz) is typically the result of running
# the builder with tar ball output enabled, and its name should match the
# generated pipeline artifact you want to deploy.
ADD changenet.tgz /workspace

RUN groupadd --gid 1000 --non-unique nvs && \
    useradd --create-home --shell /usr/sbin/nologin --uid 1000 --non-unique --gid 1000 nvs && \
    chown 1000.1000 /workspace

USER nvs:1000

# Create the entrypoint script that runs the generated
# /workspace/__main__.py (the Inference Builder pipeline entrypoint)
# and then starts Triton with /workspace/model_repo as the model repository.
RUN touch /workspace/start_server.sh && \
    chmod a+rx /workspace/start_server.sh && \
    cat > /workspace/start_server.sh <<-EOF
	#!/usr/bin/env bash
	set -eu

	# SPDX-FileCopyrightText: Copyright (c) 2024-2026 NVIDIA CORPORATION & AFFILIATES. All rights reserved.
	# SPDX-License-Identifier: LicenseRef-NvidiaProprietary
    python3 /workspace/__main__.py & tritonserver --model-repository /workspace/model_repo
#    while true; do sleep 5; done
EOF

ENTRYPOINT ["/workspace/start_server.sh"]
CMD []