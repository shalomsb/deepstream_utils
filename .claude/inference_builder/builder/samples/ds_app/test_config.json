[
  {
    "name": "gdino_video_inference",
    "description": "Test gdino inference application with video input",
    "build_args": {
      "TEST_APP_NAME": "deepstream-app",
      "CACHE_BUSTER": "gdino_video_test",
      "APP_YAML_PATH": "./gdino/ds_gdino.yaml",
      "OUTPUT_DIR": ".",
      "PROCESSORS_PATH": "../tao/processors.py",
      "SERVER_TYPE": "serverless"
    },
    "test_config": {
      "default_enable": true,
      "timeout": 600,
      "env": {
        "NVSTREAMMUX_ADAPTIVE_BATCHING": "yes",
        "NVIDIA_DRIVER_CAPABILITIES": "compute,utility,video,graphics"
      },
      "volumes": {
        "/tmp/model-repo/gdino": "/workspace/models/gdino"
      },
      "cmd": [
        "--media-url",
        "/opt/nvidia/deepstream/deepstream/samples/streams/sample_1080p_h264.mp4",
        "--mime",
        "video/mp4",
        "--text",
        "car,person"
      ],
      "prerequisite_script": null,
      "models": {
        "gdino": {
          "source": "NGC",
          "target": "/tmp/model-repo",
          "path": "nvidia/tao/grounding_dino",
          "version": "grounding_dino_swin_tiny_commercial_deployable_v1.0",
          "configs": "./gdino/gdino"
        }
      }
    }
  },
