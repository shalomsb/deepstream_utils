# Sample Dockerfile for an NVCLIP embedding model pipeline that uses
# DeepStream for hardware-accelerated video decoding and a
# TensorRT backend for inference. This is a reference for this specific
# sample, not a universal template for all deployments.em
FROM "nvcr.io/nvidia/deepstream:9.0-triton-multiarch" AS builder_base

# Install Python dependencies required by THIS NVCLIP sample (CLIP
# model, TensorRT bindings, FastAPI server, etc.). Versions are pinned
# for reproducibility and can be adjusted for other pipelines.
RUN --mount=type=cache,target=/root/.cache/pip \
    pip install \
    requests==2.32.3 \
    python-multipart==0.0.9 \
    aiofiles==23.2.1 \
    aiohttp==3.11.0 \
    annotated-types==0.7.0 \
    python-magic==0.4.27 \
    Pillow==11.1.0 \
    open_clip_torch==3.2.0 \
    numpy==1.26.4 \
    omegaconf==2.3.0 \
    transformers==4.48.1 \
    fastapi==0.115.12 \
    uvicorn==0.29.0 \
    tensorrt==10.14.1.48.post1 --extra-index-url https://pypi.nvidia.com \
    polygraphy==0.49.24
ENV TRANSFORMERS_CACHE=/tmp

WORKDIR /workspace

# Copy the inference flow package generated by Inference Builder. This
# tarball (here: nvclip.tgz) is typically produced when running the
# builder with tarball output enabled, and its name should match the
# generated pipeline artifact you want to deploy.
ADD nvclip.tgz /workspace

RUN groupadd --gid 1000 --non-unique nvs && \
    useradd --create-home --shell /usr/sbin/nologin --uid 1000 --non-unique --gid 1000 nvs && \
    chown 1000.1000 /workspace

USER nvs:1000

# Create the entrypoint script that runs the Inference Builder‑generated
# /workspace/__main__.py for this NVCLIP pipeline. Uncomment the
# while‑loop or alternative ENTRYPOINT for debugging if desired.
RUN touch /workspace/start_server.sh && \
    chmod a+rx /workspace/start_server.sh && \
    cat > /workspace/start_server.sh <<-EOF
	#!/usr/bin/env bash
	set -eu

	# SPDX-FileCopyrightText: Copyright (c) 2024-2026 NVIDIA CORPORATION & AFFILIATES. All rights reserved.
	# SPDX-License-Identifier: LicenseRef-NvidiaProprietary
    python3 /workspace/__main__.py
#    while true; do sleep 5; done
EOF

ENTRYPOINT ["/workspace/start_server.sh"]
#ENTRYPOINT ["/bin/bash"]
CMD []