[
  {
    "name": "tao_gdino_video_inference",
    "description": "Test TAO Grounding DINO inference with video input",
    "build_args": {
      "TEST_APP_NAME": "tao-cv",
      "CACHE_BUSTER": "tao_gdino_video_test",
      "APP_YAML_PATH": "ds_gdino.yaml",
      "OUTPUT_DIR": ".",
      "PROCESSORS_PATH": "processors.py",
      "SERVER_TYPE": "fastapi",
      "OPENAPI_SPEC": "openapi.yaml"
    },
    "test_config": {
      "default_enable": true,
      "timeout": 1000,
      "env": {
        "NVSTREAMMUX_ADAPTIVE_BATCHING": "yes",
        "NVIDIA_DRIVER_CAPABILITIES": "compute,utility,video,graphics",
        "MODEL_REPO": "/workspace/.cache/model-repo",
        "TAO_MODEL_NAME": "gdino",
        "TEST_TOLERANCE": "1"
      },
      "volumes": {
        "/tmp/model-repo": "/workspace/.cache/model-repo"
      },
      "auto_validation": "./validation/gdino",
      "prerequisite_script": null,
      "models": {
        "gdino": {
          "source": "NGC",
          "target": "/tmp/model-repo",
          "path": "nvidia/tao/grounding_dino",
          "version": "grounding_dino_swin_tiny_commercial_deployable_v1.0",
          "configs": "../ds_app/gdino/gdino"
        }
      }
    }
  },
