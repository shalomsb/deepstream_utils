[
  {
    "name": "frame_sampling_on_files",
    "description": "Test with default TensorRT and CUDA versions",
    "build_args": {
      "TEST_APP_NAME": "frame_sampling",
      "CACHE_BUSTER": "default_test"
    },
    "test_config": {
      "default_enable": true,
      "timeout": 30,
      "env": {
        "NVSTREAMMUX_ADAPTIVE_BATCHING": "yes"
      },
      "volumes": {
        "frame_sampling/models": "/workspace/models"
      },
      "cmd": [
        "--video-files", "file:///opt/nvidia/deepstream/deepstream/samples/streams/sample_1080p_h265.mp4?frames=10&start=0&duration=10000000000"
      ],
      "prerequisite_script": null
    }
  },
  {
    "name": "frame_sampling_on_streams",
    "description": "Test with default TensorRT and CUDA versions",
    "build_args": {
      "TEST_APP_NAME": "frame_sampling",
      "CACHE_BUSTER": "default_test"
    },
    "test_config": {
      "default_enable": false,
      "timeout": 30,
      "env": {
        "NVSTREAMMUX_ADAPTIVE_BATCHING": "yes"
      },
      "volumes": {
        "frame_sampling/models": "/workspace/models"
      },
      "cmd": [
        "--video-streams", "rtsp://localhost:8554/test?frames=10&interval=100000000&chunks=3&scale=640x360"
      ],
      "prerequisite_script": "./setup_rtsp_server.sh frame.jpg -m test -f 30 --daemon"
    }
  },
  {
    "name": "asset_upload_test",
    "description": "Test asset upload",
    "build_args": {
      "TEST_APP_NAME": "asset_management",
      "CACHE_BUSTER": "asset_management",
      "SERVER_TYPE": "fastapi",
      "OPENAPI_SPEC": "builder/samples/dummy/openapi.yaml"
    },
    "test_config": {
      "default_enable": true,
      "timeout": 5,
      "env": {
        "MODEL_REPO": "/workspace/model-repo"
      },
      "volumes": {
        "asset_management/models": "/workspace/models"
      },
      "ports": {
        "8000": "8000"
      },
      "test_requests": [
        {
          "payload_path": "asset_management/payloads/assets.jsonl",
          "method": "POST",
          "headers": {
            "Content-Type": "multipart/form-data"
          }
        },
        {
          "method": "GET",
          "headers": {
            "Content-Type": "application/json"
          }
        }
      ],
      "endpoint": "/v1/files"
    }
  },
  {
    "name": "Output Types Compatibility Test",
