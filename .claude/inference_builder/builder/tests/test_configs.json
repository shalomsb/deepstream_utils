  {
    "name": "live_stream_graceful_deletion_test",
    "description": "Test graceful deletion of RTSP stream during processing",
    "build_args": {
      "TEST_APP_NAME": "asset_management",
      "CACHE_BUSTER": "live_stream_deletion",
      "SERVER_TYPE": "fastapi",
      "OPENAPI_SPEC": "builder/tests/asset_management/openapi.yaml"
    },
    "test_config": {
      "default_enable": false,
      "timeout": 120,
      "env": {
        "NVSTREAMMUX_ADAPTIVE_BATCHING": "yes",
        "DEBUG": "0",
        "HTTP_PORT": "8000"
      },
      "volumes": {
        "asset_management/models": "/workspace/models"
      },
      "ports": {
        "8000": "8000"
      },
      "assets": [
        {
          "assetId": "00000000-0000-4000-8000-000000000001",
          "path": "rtsp://localhost:8554/test",
          "fileName": "",
          "mimeType": "",
          "duration": 0,
          "username": "",
          "password": "",
          "description": "Test RTSP stream for graceful deletion",
          "size": 0,
          "live": true
        }
      ],
      "test_requests": [
        {
          "scheduled_time": 10,
          "method": "POST",
          "endpoint": "/v1/inference",
          "payload_path": "asset_management/payloads/start_stream.jsonl",
          "async": true
        },
        {
          "scheduled_time": 15,
          "method": "DELETE",
          "endpoint": "/v1/live-streams/00000000-0000-4000-8000-000000000001"
        }
      ],
      "prerequisite_script": "./setup_rtsp_server.sh frame.jpg -m test -f 30 --daemon"
    }
  }
]
