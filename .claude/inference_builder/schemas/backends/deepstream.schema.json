{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://raw.githubusercontent.com/NVIDIA-AI-IOT/inference_builder/main/schemas/backends/deepstream.schema.json",
  "title": "DeepStream Backend Configuration",
  "description": "Schema for DeepStream backend model configuration",
  "allOf": [
    {
      "$ref": "../common/base-model.schema.json"
    },
    {
      "properties": {
        "backend": {
          "type": "string",
          "enum": ["deepstream/nvinfer", "deepstream/nvinferserver"],
          "description": "DeepStream backend type"
        },
        "parameters": {
          "$ref": "parameters/deepstream-parameters.schema.json"
        }
      }
    }
  ],
  "examples": [
    {
      "name": "tao",
      "backend": "deepstream/nvinfer",
      "max_batch_size": 1,
      "parameters": {
        "infer_config_path": ["nvdsinfer_config.yaml"]
      },
      "input": [
        {
          "name": "image",
          "data_type": "TYPE_CUSTOM_DS_IMAGE",
          "dims": [-1, -1, 3]
        }
      ],
      "output": [
        {
          "name": "output",
          "data_type": "TYPE_CUSTOM_DS_METADATA",
          "dims": [-1]
        }
      ]
    }
  ]
}
